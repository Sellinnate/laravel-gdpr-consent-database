{
  "title": "Laravel GDPR Consent Manager",
  "url": "https://sellinnate.github.io/laravel-gdpr-consent-database",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Selli — Laravel GDPR Consent Manager. MIT License.",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "system",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Introduction", "path": "/", "icon": "home" },
    {
      "title": "Getting Started",
      "icon": "rocket",
      "collapsible": false,
      "children": [
        { "title": "Installation", "path": "/getting-started/installation", "icon": "download" },
        { "title": "Quick Start", "path": "/getting-started/quick-start", "icon": "play" },
        { "title": "Core Concepts", "path": "/getting-started/concepts", "icon": "book-open" }
      ]
    },
    {
      "title": "Usage",
      "icon": "code",
      "children": [
        { "title": "Consent Types", "path": "/usage/consent-types", "icon": "list" },
        { "title": "User Consents", "path": "/usage/user-consents", "icon": "user-check" },
        { "title": "Versioning", "path": "/usage/versioning", "icon": "git-branch" },
        { "title": "Expiration & Renewal", "path": "/usage/expiration", "icon": "clock" },
        { "title": "Guest Consents", "path": "/usage/guest-consents", "icon": "users" },
        { "title": "Cookie Banner", "path": "/usage/cookie-banner", "icon": "cookie" }
      ]
    },
    {
      "title": "Compliance",
      "icon": "shield",
      "children": [
        { "title": "GDPR Mapping", "path": "/compliance/gdpr-mapping", "icon": "scale" },
        { "title": "Audit Trail", "path": "/compliance/audit-trail", "icon": "history" },
        { "title": "Data Subject Rights", "path": "/compliance/data-subject-rights", "icon": "user-x" }
      ]
    },
    {
      "title": "Configuration",
      "icon": "cog",
      "children": [
        { "title": "Overview", "path": "/configuration/overview", "icon": "sliders" }
      ]
    },
    {
      "title": "Reference",
      "icon": "book",
      "children": [
        { "title": "Artisan Commands", "path": "/reference/commands", "icon": "terminal" },
        { "title": "Database Schema", "path": "/reference/database-schema", "icon": "database" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/sellinnate/laravel-gdpr-consent-database", "icon": "github", "external": true }
  ],
  "plugins": {
    "seo": {
      "defaultDescription": "Enterprise-grade GDPR consent management for Laravel: consent types, versioning, expiration, guest consents, audit trail and a configurable cookie banner."
    }
  }
}
