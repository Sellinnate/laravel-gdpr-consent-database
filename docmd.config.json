{
  "title": "Laravel GDPR Consent Manager",
  "url": "https://laravel-gdpr-consent.selli.io",
  "src": "docs",
  "out": "site",
  "engine": "js",
  "layout": {
    "spa": true,
    "header": {
      "enabled": true
    },
    "sidebar": {
      "collapsible": true,
      "defaultCollapsed": false
    },
    "optionsMenu": {
      "position": "sidebar-top",
      "components": {
        "search": true,
        "themeSwitch": true
      }
    },
    "footer": {
      "style": "minimal",
      "content": "© 2026 Sellinnate S.r.l. — GDPR Consent Manager for Laravel (MIT).",
      "branding": true
    }
  },
  "theme": {
    "name": "default",
    "appearance": "dark",
    "codeHighlight": true
  },
  "minify": true,
  "autoTitleFromH1": true,
  "copyCode": true,
  "pageNavigation": true,
  "navigation": [
    { "title": "Introduction", "path": "/", "icon": "home" },
    {
      "title": "Getting Started",
      "icon": "rocket",
      "collapsible": false,
      "children": [
        { "title": "What is GDPR consent? (start here)", "path": "/getting-started/what-is-gdpr-consent", "icon": "lightbulb" },
        { "title": "Installation", "path": "/getting-started/installation", "icon": "download" },
        { "title": "Quick Start", "path": "/getting-started/quick-start", "icon": "zap" }
      ]
    },
    {
      "title": "Concepts",
      "icon": "book-open",
      "children": [
        { "title": "Architecture & data model", "path": "/concepts/architecture", "icon": "layout" },
        { "title": "Consent types & purposes", "path": "/concepts/consent-types", "icon": "list" },
        { "title": "Versioning & re-consent", "path": "/concepts/versioning", "icon": "git-branch" },
        { "title": "The audit trail", "path": "/concepts/audit-trail", "icon": "history" },
        { "title": "Erasure & pseudonymisation", "path": "/concepts/erasure", "icon": "user-x" },
        { "title": "IP & data minimisation", "path": "/concepts/data-and-privacy", "icon": "eye-off" },
        { "title": "Guest consents", "path": "/concepts/guest-consents", "icon": "users" },
        { "title": "Cookie banner & ePrivacy", "path": "/concepts/cookie-banner", "icon": "cookie" },
        { "title": "Events & integration", "path": "/concepts/events", "icon": "radio" }
      ]
    },
    {
      "title": "Guides",
      "icon": "compass",
      "children": [
        { "title": "Recording & checking consent", "path": "/guides/recording-consent", "icon": "user-check" },
        { "title": "Expiration & renewal", "path": "/guides/expiration", "icon": "clock" }
      ]
    },
    {
      "title": "Compliance",
      "icon": "shield",
      "children": [
        { "title": "GDPR article mapping", "path": "/compliance/gdpr-mapping", "icon": "scale" },
        { "title": "Data subject rights", "path": "/compliance/data-subject-rights", "icon": "file-text" },
        { "title": "Scope & limitations", "path": "/compliance/limitations", "icon": "alert-octagon" }
      ]
    },
    {
      "title": "Configuration",
      "icon": "cog",
      "children": [
        { "title": "Overview", "path": "/configuration/overview", "icon": "sliders" }
      ]
    },
    {
      "title": "Reference",
      "icon": "book",
      "children": [
        { "title": "Artisan commands", "path": "/reference/commands", "icon": "terminal" },
        { "title": "Database schema", "path": "/reference/database-schema", "icon": "database" }
      ]
    },
    { "title": "GitHub", "path": "https://github.com/sellinnate/laravel-gdpr-consent-database", "icon": "github", "external": true }
  ],
  "plugins": {
    "seo": {
      "defaultDescription": "Enterprise-grade GDPR consent management for Laravel: consent types, versioning, expiration, guest consents, audit trail and a configurable cookie banner."
    }
  }
}
